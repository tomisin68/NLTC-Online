// firestore.rules
// Deploy with: firebase deploy --only firestore:rules
//
// ═══════════════════════════════════════════════════════════════════════
//  COLLECTIONS IN USE
// ═══════════════════════════════════════════════════════════════════════
//
//  /users/{uid}                          — all HTML files
//  /users/{uid}/progress/{id}            — dashboard.html
//  /users/{uid}/results/{id}             — dashboard.html (CBT)
//  /users/{uid}/notifications/{id}       — dashboard.html, notifications.html
//  /xpLog/{id}                           — backend (Admin SDK) only
//  /cbtSessions/{id}                     — backend (Admin SDK) only
//  /questions/{id}                       — admin.html (write), dashboard.html (read)
//  /videos/{id}                          — admin.html (write), dashboard.html (read)
//  /courses/{id}                         — coursemanagement.html
//  /courses/{id}/lessons/{id}            — coursemanagement.html
//  /liveSessions/{id}                    — admin.html, dashboard.html, livestream.html
//  /liveSessions/{id}/messages/{id}      — dashboard.html, livestream.html
//  /teachers/{id}                        — admin.html
//  /broadcasts/{id}                      — admin.html, notifications.html (read+write), dashboard.html (read)
//  /announcements/{id}                   — legacy alias for broadcasts
//  /schedule/{id}                        — admin.html (write), dashboard.html (read)
//  /leaderboard/{id}                     — Cloud Function writes; dashboard/index.html reads
//  /subscriptions/{id}                   — Paystack webhook via Admin SDK
//  /quickTests/{id}                      — admin.html (write), dashboard.html (read published only)
//  /quickTestResults/{id}                — dashboard.html (student writes own), admin.html (reads all)
//
//  ROLE STORAGE (dual-location for reliability):
//    1. Firestore /users/{uid}.role       — set at signup (auth.html saveUser)
//    2. Firebase Auth custom claims       — set by Admin SDK (optional, faster)
//  Rules check custom claims first (fast path), then fall back to Firestore get().
//
//  ANONYMOUS AUTH:
//    index.html uses signInAnonymously to read the leaderboard without a real account.
//    isAnonymous() guards all write paths so anonymous users cannot mutate data.
//
// ═══════════════════════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════
    //  CORE HELPERS
    // ═══════════════════════════════════════════════════════════════

    // Any authenticated principal (including anonymous)
    function isSignedIn() {
      return request.auth != null;
    }

    // Anonymous sign-in (used on the landing page for leaderboard reads)
    function isAnonymous() {
      return isSignedIn()
          && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    // Real (non-anonymous) signed-in user
    function isRealUser() {
      return isSignedIn() && !isAnonymous();
    }

    // Document belongs to the requesting user
    function isOwner(uid) {
      return isRealUser() && request.auth.uid == uid;
    }

    // Admin: custom claim (fast) → Firestore role fallback
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.get('admin', false) == true
        ||
        get(/databases/$(database)/documents/users/$(request.auth.uid))
          .data.get('role', '') == 'admin'
      );
    }

    // Teacher (includes admins): custom claim → Firestore role fallback
    function isTeacher() {
      return isSignedIn() && (
        request.auth.token.get('teacher', false) == true
        || request.auth.token.get('admin',   false) == true
        ||
        get(/databases/$(database)/documents/users/$(request.auth.uid))
          .data.get('role', '') in ['teacher', 'admin']
      );
    }

    // Fields that only the backend (Admin SDK) may change
    function touchesProtectedFields() {
      let protected = [
        'xp', 'streak', 'plan', 'role',
        'paystackRef', 'planActivatedAt', 'planExpiresAt',
        'lastActivityAt', 'subscriptionId'
      ];
      return request.resource.data.diff(resource.data)
               .affectedKeys()
               .hasAny(protected);
    }

    // ═══════════════════════════════════════════════════════════════
    //  USERS  /users/{uid}
    // ═══════════════════════════════════════════════════════════════

    match /users/{uid} {

      // READ — any signed-in user (including anonymous, for landing page leaderboard)
      allow read: if isSignedIn();

      // CREATE
      //   • Real user creates their own profile doc on sign-up (auth.html saveUser)
      //   • Admin creates placeholder docs manually from the admin panel
      allow create: if (isOwner(uid) && validNewUser())
                    || isAdmin();

      // UPDATE
      //   • Owner: only safe profile fields, no protected fields
      //   • Admin: anything (plan upgrades, manual corrections)
      allow update: if (isOwner(uid) && !touchesProtectedFields() && validProfileUpdate())
                    || isAdmin();

      // DELETE — admin only
      allow delete: if isAdmin();
    }

    // ── Per-user learning progress ──
    match /users/{uid}/progress/{progressId} {
      allow read:           if isOwner(uid) || isAdmin();
      allow create, update: if isOwner(uid) && validProgressWrite();
      allow delete:         if isAdmin();
    }

    // ── CBT session results — immutable once written ──
    match /users/{uid}/results/{resultId} {
      allow read:           if isOwner(uid) || isAdmin();
      allow create:         if isOwner(uid) && validResultData();
      allow update, delete: if isAdmin();
    }

    // ── In-app notifications — backend writes; user reads/marks-read/deletes ──
    match /users/{uid}/notifications/{notifId} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if false; // Admin SDK only — never from the client
      allow update: if (isOwner(uid) && onlyMarkReadChange()) || isAdmin();
      allow delete: if isOwner(uid) || isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    //  XP LOG  — Admin SDK only
    // ═══════════════════════════════════════════════════════════════

    match /xpLog/{docId} {
      allow read:  if isRealUser() &&
                      (resource.data.get('uid', '') == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // ═══════════════════════════════════════════════════════════════
    //  CBT SESSIONS  — Admin SDK only
    // ═══════════════════════════════════════════════════════════════

    match /cbtSessions/{sessionId} {
      allow read:  if isRealUser() &&
                      (resource.data.get('userId', '') == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // ═══════════════════════════════════════════════════════════════
    //  QUESTIONS  /questions/{questionId}
    // ═══════════════════════════════════════════════════════════════

    match /questions/{questionId} {
      allow read:           if isRealUser();
      allow create, update: if isTeacher() && validQuestionWrite();
      allow delete:         if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    //  VIDEOS  /videos/{videoId}
    // ═══════════════════════════════════════════════════════════════

    match /videos/{videoId} {
      allow read:           if isRealUser();
      allow create, update: if isTeacher() && validVideoWrite();
      allow delete:         if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    //  COURSES + LESSONS  /courses/{courseId}[/lessons/{lessonId}]
    // ═══════════════════════════════════════════════════════════════

    match /courses/{courseId} {
      allow read:           if isRealUser();
      allow create, update: if isTeacher();
      allow delete:         if isAdmin();
    }

    match /courses/{courseId}/lessons/{lessonId} {
      allow read:           if isRealUser();
      allow create, update: if isTeacher();
      allow delete:         if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    //  LIVE SESSIONS  /liveSessions/{sessionId}
    // ═══════════════════════════════════════════════════════════════

    match /liveSessions/{sessionId} {
      allow read: if isSignedIn(); // anonymous ok (read-only public listing)

      allow create: if isTeacher() && validLiveSessionCreate();

      // Host teacher or admin can update full metadata.
      // Real students may ONLY bump viewerCount ±1 (joining/leaving).
      allow update: if isAdmin()
                    || (isTeacher() && resource.data.get('hostId', '') == request.auth.uid)
                    || (isRealUser() && onlyViewerCountChange());

      allow delete: if isAdmin();
    }

    // ── Live class chat ──
    match /liveSessions/{sessionId}/messages/{messageId} {
      allow read:           if isSignedIn();
      allow create:         if isRealUser() && validChatMessage();
      allow update, delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    //  TEACHERS  /teachers/{teacherId}
    // ═══════════════════════════════════════════════════════════════

    match /teachers/{teacherId} {
      allow read:  if isRealUser();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    //  BROADCASTS  /broadcasts/{docId}
    //  Also: /announcements/{docId}  — legacy collection alias
    // ═══════════════════════════════════════════════════════════════

    match /broadcasts/{docId} {
      allow read:  if isSignedIn(); // real users + anonymous (public announcements)
      allow write: if isAdmin();
    }

    match /announcements/{docId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    //  SCHEDULE  /schedule/{docId}
    // ═══════════════════════════════════════════════════════════════

    match /schedule/{docId} {
      allow read:  if isSignedIn();
      allow write: if isTeacher(); // isTeacher() includes admins
    }

    // ═══════════════════════════════════════════════════════════════
    //  LEADERBOARD  — Cloud Function writes only
    // ═══════════════════════════════════════════════════════════════

    match /leaderboard/{entryId} {
      allow read:  if isSignedIn(); // landing page reads via anonymous auth
      allow write: if false;
    }

    // ═══════════════════════════════════════════════════════════════
    //  SUBSCRIPTIONS  — Paystack webhook via Admin SDK only
    // ═══════════════════════════════════════════════════════════════

    match /subscriptions/{subId} {
      allow read:  if isOwner(subId) || isAdmin();
      allow write: if false;
    }

    // ═══════════════════════════════════════════════════════════════
    //  MOCK EXAMS  /mockExams/{examId}
    // ═══════════════════════════════════════════════════════════════

    match /mockExams/{examId} {
      // Students see active exams only; admins see all
      allow read: if isRealUser() &&
                     (resource.data.get('status', '') == 'active' || isAdmin());
      allow create, update: if isAdmin();
      allow delete:         if isAdmin();
    }

    // ── Mock exam submissions — student writes own once; admin reads all ──
    match /mockExams/{examId}/submissions/{uid} {
      allow read:           if isAdmin() || isOwner(uid);
      allow create:         if isOwner(uid);
      allow update, delete: if isAdmin();
    }

    // ── Lesson fee payments — student writes own; admin reads all ──
    match /users/{uid}/lessonFeePayments/{paymentId} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isAdmin(); // backend marks status=success
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    //  PHYSICAL CENTRES  /centers/{centerId}
    // ═══════════════════════════════════════════════════════════════

    match /centers/{centerId} {
      allow read:           if isRealUser();   // any signed-in user can fetch centres for signup
      allow create, update: if isAdmin();
      allow delete:         if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    //  QUICK TESTS  /quickTests/{testId}
    // ═══════════════════════════════════════════════════════════════

    match /quickTests/{testId} {
      // Real users can read published tests; admins can read all (draft + published)
      allow read: if isRealUser() &&
                     (resource.data.get('status', '') == 'published' || isAdmin());
      allow create, update: if isAdmin();
      allow delete:         if isAdmin();
    }

    // ── Quick test submissions — student writes once; admin reads all ──
    match /quickTestResults/{resultId} {
      // Admin sees all results; students see only their own
      allow read:           if isAdmin()
                            || (isRealUser() && resource.data.get('uid', '') == request.auth.uid);
      allow create:         if isRealUser() && validQTResult();
      allow update, delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    //  DENY ALL — catch-all (must be last)
    // ═══════════════════════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if false;
    }


    // ═══════════════════════════════════════════════════════════════
    //  VALIDATION FUNCTIONS
    // ═══════════════════════════════════════════════════════════════

    // ── New user profile (CREATE via auth.html saveUser) ──
    function validNewUser() {
      let d = request.resource.data;
      return d.get('uid', '')   == request.auth.uid
          && d.get('email', '') == request.auth.token.email;
    }

    // ── Profile self-update (safe fields only) ──
    function validProfileUpdate() {
      let allowed = [
        'displayName', 'photoURL', 'phone',       'state',
        'targetExam',  'bio',      'lastLogin',    'updatedAt',
        'fcmToken',    'firstName','lastName',     'notifPrefs',
        'email',       'uid',      'studentMode',  'centerId',  'centerName'
      ];
      return request.resource.data
               .diff(resource.data)
               .affectedKeys()
               .hasOnly(allowed);
    }

    // ── Lesson progress node ──
    function validProgressWrite() {
      let d = request.resource.data;
      return d.keys().hasAll(['lessonId', 'completedAt', 'watchedSeconds'])
          && d.lessonId       is string
          && d.lessonId.size() > 0
          && d.watchedSeconds is int
          && d.watchedSeconds >= 0
          && d.completedAt    is timestamp;
    }

    // ── CBT result (subcollection under /users/{uid}/results) ──
    function validResultData() {
      let d = request.resource.data;
      return d.keys().hasAll(['exam', 'score', 'total', 'submittedAt'])
          && d.exam        is string
          && d.exam.size() > 0
          && d.score       is int
          && d.total       is int
          && d.score       >= 0
          && d.score       <= d.total
          && d.submittedAt is timestamp;
    }

    // ── CBT question document ──
    function validQuestionWrite() {
      let d = request.resource.data;
      return d.get('question', d.get('text', '')) is string
          && d.get('question', d.get('text', '')).size() > 0
          && d.get('subject', '') is string
          && d.get('subject', '').size() > 0;
    }

    // ── Video lesson document ──
    function validVideoWrite() {
      let d = request.resource.data;
      return d.get('title', '') is string
          && d.get('title', '').size() > 0
          && d.get('subject', '') is string
          && (d.get('videoUrl', d.get('cloudinaryUrl', '')) is string);
    }

    // ── Live session CREATE ──
    function validLiveSessionCreate() {
      let d = request.resource.data;
      return d.get('title',   '') is string
          && d.get('title',   '').size() > 0
          && d.get('channel', '') is string
          && d.get('channel', '').size() > 0
          && d.get('hostId',  '') == request.auth.uid;
    }

    // ── Students may only increment/decrement viewerCount by 1 ──
    function onlyViewerCountChange() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let cur   = resource.data.get('viewerCount', 0);
      let next  = request.resource.data.get('viewerCount', 0);
      let delta = next - cur;
      return changed.hasOnly(['viewerCount'])
          && (delta == 1 || delta == -1);
    }

    // ── Notification self-update: only the 'read' field, only set to true ──
    function onlyMarkReadChange() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(['read'])
          && request.resource.data.get('read', false) == true;
    }

    // ── Live chat message ──
    function validChatMessage() {
      let d = request.resource.data;
      return d.get('senderId',   '') == request.auth.uid
          && d.get('text',       '') is string
          && d.get('text',       '').size() > 0
          && d.get('text',       '').size() <= 500
          && d.get('senderName', '') is string;
    }

    // ── Quick test result (top-level collection) ──
    function validQTResult() {
      let d = request.resource.data;
      return d.get('uid',    '') == request.auth.uid
          && d.get('testId', '') is string
          && d.get('testId', '').size() > 0
          && d.get('score',  0) is int
          && d.get('total',  1) is int
          && d.get('score',  0) >= 0
          && d.get('score',  0) <= d.get('total', 1);
    }

  }
}
